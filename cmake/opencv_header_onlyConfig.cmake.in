@PACKAGE_INIT@

include("${CMAKE_CURRENT_LIST_DIR}/opencv_header_onlyTargets.cmake")

# Convenience target alias for installed packages.
if(TARGET cvh::full_backend AND NOT TARGET cvh::full)
    add_library(cvh::full INTERFACE IMPORTED)
    set_property(TARGET cvh::full PROPERTY INTERFACE_LINK_LIBRARIES cvh::full_backend)
endif()
